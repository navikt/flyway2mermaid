{
  "name": "@navikt/flyway2mermaid",
  "version": "0.1.0",
  "description": "Generate Mermaid ER diagrams from Flyway SQL migration files",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "flyway2mermaid": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . && tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepublishOnly": "npm run build",
    "prepare": "husky"
  },
  "keywords": [
    "flyway",
    "mermaid",
    "er-diagram",
    "database",
    "schema",
    "postgresql",
    "migration"
  ],
  "author": "NAV IT",
  "license": "MIT",
  "type": "module",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.4.0",
    "eslint": "^10.0.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "pgsql-ast-parser": "^12.0.2"
  },
  "files": [
    "dist"
  ],
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,mmd}": [
      "prettier --write"
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/navikt/flyway2mermaid.git"
  },
  "bugs": {
    "url": "https://github.com/navikt/flyway2mermaid/issues"
  },
  "homepage": "https://github.com/navikt/flyway2mermaid#readme",
  "engines": {
    "node": ">=18"
  }
}
